# §22.3 MinIO VIP + Keepalived (Tailscale interface tailscale0)
# Скопировать на оба узла хранения, задать unicast_src_ip / unicast_peer / virtual_ipaddress.

global_defs {
    script_user root
    enable_script_security
}

vrrp_script chk_minio {
    script "/etc/keepalived/check_minio.sh"
    interval 3
    weight -20
    fall 2
    rise 2
}

vrrp_instance VI_MINIO {
    state MASTER
    interface tailscale0
    virtual_router_id 51
    priority 100
    advert_int 1
    authentication {
        auth_type PASS
        auth_pass CHANGE_ME_KEEPALIVED
    }
    unicast_src_ip 100.64.0.1
    unicast_peer {
        100.64.0.2
    }
    virtual_ipaddress {
        100.64.0.10/32 dev tailscale0
    }
    track_script {
        chk_minio
    }
}
