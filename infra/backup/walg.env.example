# §9.4 WAL-G — пример env для incremental backup + PITR
# Скопировать в prod secrets и настроить cron на узле PostgreSQL.

WALG_S3_PREFIX=s3://db-backups/wal-g
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT=http://minio-node-a:9000
AWS_S3_FORCE_PATH_STYLE=true
PGDATA=/var/lib/postgresql/data
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGDATABASE=kwork

# Полный бэкап ежедневно 02:00 UTC:
# wal-g backup-push $PGDATA

# WAL archive каждые 6ч (через archive_command в postgresql.conf):
# archive_command = 'wal-g wal-push %p'

# GPG шифрование (§9.4):
# WALG_LIBSODIUM_KEY=$(cat /run/secrets/walg_gpg_key)
